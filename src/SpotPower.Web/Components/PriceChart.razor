@using SpotPower.Web.Models

@if (Prices is { Count: > 0 })
{
    var minPrice = Prices.Min(p => p.PriceEurPerMwh);
    var maxPrice = Prices.Max(p => p.PriceEurPerMwh);
    var range = maxPrice - minPrice == 0 ? 1 : maxPrice - minPrice;

    const int width = 900;
    const int height = 260;
    const int padding = 30;

    var points = string.Join(" ", Prices.Select((p, i) =>
    {
        var x = padding + i * (double)(width - 2 * padding) / (Prices.Count - 1);
        var y = height - padding - (double)((p.PriceEurPerMwh - minPrice) / range) * (height - 2 * padding);
        return $"{x.ToString(System.Globalization.CultureInfo.InvariantCulture)},{y.ToString(System.Globalization.CultureInfo.InvariantCulture)}";
    }));

    <svg viewBox="0 0 @width @height" style="width:100%; height:auto; background:#fafafa; border:1px solid #ddd;">
        <polyline points="@points" fill="none" stroke="#2563eb" stroke-width="2" />
        <text x="@padding" y="15" font-size="12" fill="#555">@maxPrice.ToString("F2") €/MWh</text>
        <text x="@padding" y="@(height - 10)" font-size="12" fill="#555">@minPrice.ToString("F2") €/MWh</text>
        <text x="@(width - 120)" y="15" font-size="12" fill="#555">@Prices[0].Zone — @Prices[0].PeriodStartCet.ToString("yyyy-MM-dd")</text>
    </svg>
}
else
{
    <p><em>No data to display.</em></p>
}

@code {
    [Parameter] public List<DayAheadPricePointDto>? Prices { get; set; }
}